# PostgreSQL connection used by SQLAlchemy
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/jobmonitor

# Signed login token secret. Use a long random value in production.
JOBMONITOR_SECRET=dev-secret-change-me

# Used only when the users table is empty. In production, this password is
# required so the app will not silently create admin/admin123.
JOBMONITOR_ADMIN_USERNAME=admin
JOBMONITOR_ADMIN_PASSWORD=admin123

GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_ALLOWED_EMAILS=admin@example.com,eartechboung@gmail.com

# Multi-firm scrapes run concurrently. Keep this conservative when browsers
# share a small Render instance; accepted values are capped at 8.
SCRAPE_MAX_WORKERS=3
